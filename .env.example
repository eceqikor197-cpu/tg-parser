# Скопируй этот файл в .env и заполни своими данными
# ВАЖНО: Не коммить .env в git!

# Получи на https://my.telegram.org -> API development tools
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Юзернейм канала (с @ или без) или числовой ID
CHANNEL_USERNAME=@channel_name

# Имя сессии (можно оставить как есть)
SESSION_NAME=my_session
